{
  "expo": {
    "name": "Converter PDF: Fast & Offline",
    "slug": "ameda-image-to-pdf",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ameda",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara solo cuando eliges tomar una foto para convertirla a PDF.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso solo a las imágenes que selecciones para convertirlas o exportarlas.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos permiso para exportar archivos generados por la app cuando tú lo solicitas.",
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.amedastudios.img2pdf"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necesitamos acceso a la cámara solo cuando eliges tomar una foto para convertirla a PDF.",
          "photosPermission": "Necesitamos acceso solo a las imágenes que selecciones para convertirlas o exportarlas.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1944424443685697~3527490774",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF4D4F",
          "dark": {
            "backgroundColor": "#FF4D4F"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "billing": {
        "android": {
          "productId": "premium_subscription",
          "basePlans": {
            "monthly": "premium-monthly",
            "yearly": "premium-yearly"
          }
        }
      },
      "ads": {
        "android": {
          "banner": "ca-app-pub-1944424443685697/9901327436",
          "interstitial": "ca-app-pub-1944424443685697/2808106369",
          "rewarded": "ca-app-pub-1944424443685697/7868861354"
        },
        "ios": {
          "banner": "ca-app-pub-3940256099942544/2934735716",
          "interstitial": "ca-app-pub-3940256099942544/4411468910",
          "rewarded": "ca-app-pub-3940256099942544/1712485313"
        }
      },
      "router": {},
      "eas": {
        "projectId": "abd9d209-1cfc-4519-877b-474a2e020742"
      }
    }
  }
}
