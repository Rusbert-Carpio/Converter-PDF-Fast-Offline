{
  "expo": {
    "name": "Converter Image to PDF",
    "slug": "ameda-image-to-pdf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ameda",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara solo cuando eliges tomar una foto para convertirla a PDF.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso solo a las imágenes que selecciones para convertirlas o exportarlas.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos permiso para exportar archivos generados por la app cuando tú lo solicitas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.amedastudios.img2pdf"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necesitamos acceso a la cámara solo cuando eliges tomar una foto para convertirla a PDF.",
          "photosPermission": "Necesitamos acceso solo a las imágenes que selecciones para convertirlas o exportarlas.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF4D4F",
          "dark": {
            "backgroundColor": "##FF4D4F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "ads": {
        "android": {
          "banner": "ca-app-pub-3940256099942544/6300978111",
          "interstitial": "ca-app-pub-3940256099942544/1033173712",
          "rewarded": "ca-app-pub-3940256099942544/5224354917"
        },
        "ios": {
          "banner": "ca-app-pub-3940256099942544/2934735716",
          "interstitial": "ca-app-pub-3940256099942544/4411468910",
          "rewarded": "ca-app-pub-3940256099942544/1712485313"
        }
      },
      "billing": {
        "android": {
          "productId": "premium_subscription",
          "basePlans": {
            "monthly": "premium-monthly",
            "yearly": "premium-yearly"
          }
        },
        "iosSkus": []
      },
      "router": {},
      "eas": {
        "projectId": "abd9d209-1cfc-4519-877b-474a2e020742"
      }
    }
  }
}
