{
  "expo": {
    "name": "Converter Image to PDF",
    "slug": "ameda-image-to-pdf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ameda",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para tomar fotos y convertirlas a PDF.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para seleccionar imágenes y convertirlas a PDF.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos permiso para guardar archivos generados por la app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "package": "com.amedastudios.img2pdf"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "ads": {
        "android": {
          "banner": "ca-app-pub-3940256099942544/6300978111",
          "interstitial": "ca-app-pub-3940256099942544/1033173712",
          "rewarded": "ca-app-pub-3940256099942544/5224354917"
        },
        "ios": {
          "banner": "ca-app-pub-3940256099942544/2934735716",
          "interstitial": "ca-app-pub-3940256099942544/4411468910",
          "rewarded": "ca-app-pub-3940256099942544/1712485313"
        }
      },
      "billing": {
        "android": {
          "productId": "premium_subscription",
          "basePlans": {
            "monthly": "premium-monthly",
            "yearly": "premium-yearly"
          }
        },
        "iosSkus": []
      }
    }
  }
}
